    <!-- Gripper internal self-collision -->
    <exclude body1="L_gripper" body2="L_tip_left"/>
    <exclude body1="L_gripper" body2="L_tip_right"/>
    <exclude body1="L_tip_left" body2="L_tip_right"/>
    <exclude body1="R_gripper" body2="R_tip_left"/>
    <exclude body1="R_gripper" body2="R_tip_right"/>
    <exclude body1="R_tip_left" body2="R_tip_right"/>
    <!-- Arm mount / link1 adjacency -->
    <exclude body1="L_mount" body2="L_link1"/>
    <exclude body1="R_mount" body2="R_link1"/>
    <!-- Adjacent arm links -->
    <exclude body1="L_link1" body2="L_link2"/>
    <exclude body1="L_link2" body2="L_link3"/>
    <exclude body1="L_link3" body2="L_link4"/>
    <exclude body1="L_link4" body2="L_link5"/>
